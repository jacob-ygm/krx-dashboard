# ── 키움증권 REST API 인증 ──────────────────────────────────
# openapi.kiwoom.com 에서 앱 등록 후 발급
KIWOOM_APP_KEY=LUVdarnwVQZyxJxkDi4f4OqeUUxraKmDHyQY5kwOaH0
KIWOOM_SECRET_KEY=k4msQ4Xmeh-3_edU2Nw90lqRvjKJIotIgjgwPT-fGmw

# 계좌번호 (예: 1234567890)
KIWOOM_ACCOUNT_NO=your_account_number_here

# ── 거래 모드 ────────────────────────────────────────────────
# TRADING_MODE: mock (모의투자) | real (실거래)
TRADING_MODE=mock

# DRY_RUN=true 이면 주문 직전까지만 실행 (실제 주문 전송 안 함)
DRY_RUN=true

# ── 리스크 파라미터 ──────────────────────────────────────────
# 1회 주문 최대 금액 (원)
MAX_ORDER_AMOUNT=500000

# 종목당 최대 보유 비중 (0.0 ~ 1.0)
MAX_POSITION_RATIO=0.05

# 포트폴리오 전체 최대 사용 비중 (0.0 ~ 1.0)
MAX_PORTFOLIO_RATIO=0.50
